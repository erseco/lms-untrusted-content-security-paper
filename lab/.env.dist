# lab/.env.dist — copy to lab/.env (gitignored) and adjust.
#
# Disposable multi-version Moodle lab for the isolation-probe matrix. Reuses the
# erseco/alpine-moodle image and the mod_exelearning plugin (pinned by
# fetch-plugin.sh), the same montage proven for the paper's 5.0.7 evidence.

# Moodle release tag of erseco/alpine-moodle. The matrix (run-matrix.sh) overrides
# this per version from versions.txt; this default is used by `make up`.
#   list: https://hub.docker.com/r/erseco/alpine-moodle/tags
MOODLE_VERSION=v5.0.8

# The lab is fixed to http://localhost:80 (alpine-moodle only behaves on :80). Free
# the port first if another container holds it: `docker stop <other-moodle>`.

# Disposable lab account (POC-SAFE). Not a secret.
TEST_USER_EMAIL=user@exelearning.net
TEST_USER_USERNAME=user
TEST_USER_PASSWORD=1234
